<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style Selector="Window">
        <Setter Property="FontFamily" Value="Inter" />
    </Style>

    <Style Selector="TextBlock.TitleText">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.SectionTitle">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style Selector="TextBlock.SubtleText">
        <Setter Property="Opacity" Value="0.72" />
    </Style>

    <Style Selector="TextBlock.DialogTitle">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Border.Card">
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="14" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}" />
        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}" />
    </Style>

    <Style Selector="Button.PrimaryButton">
        <Setter Property="MinWidth" Value="96" />
        <Setter Property="Padding" Value="14,8" />
    </Style>

    <Style Selector="Button.SecondaryButton">
        <Setter Property="MinWidth" Value="96" />
        <Setter Property="Padding" Value="14,8" />
    </Style>

    <Style Selector="TextBox.NumericInput">
        <Setter Property="MinWidth" Value="30" />
        <Setter Property="HorizontalContentAlignment" Value="Right" />
    </Style>
</Styles>

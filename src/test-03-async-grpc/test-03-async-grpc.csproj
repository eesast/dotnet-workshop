<Project Sdk="MSTest.Sdk/4.0.2">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>test_03_async_grpc</RootNamespace>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <UseVSTest>true</UseVSTest>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\LogAnalyzerAgent\LogAnalyzerAgent.csproj" />
    <ProjectReference Include="..\LogAnalyzerRpc\LogAnalyzerRpc.csproj" />
    <ProjectReference Include="..\LogAnalyzer\LogAnalyzer.csproj" />
    <ProjectReference Include="..\LogParser\LogParser.csproj" />
    <ProjectReference Include="..\TestUtils\TestUtils.csproj" />
	<None Include="..\dataset\**\*.log">
	  <Link>dataset\%(RecursiveDir)%(Filename)%(Extension)</Link>
	  <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	</None>
  </ItemGroup>

</Project>
